{
  "name": "anime-tts",
  "description": "Anime TTS + terminal effects for Claude Code. Breathy Rei Ayanami voiceover (ElevenLabs), sparkles, and sound FX on session events.",
  "version": "1.1.0",
  "license": "MIT",
  "homepage": "https://github.com/leancoderkavy/anime-tts",
  "repository": "https://github.com/leancoderkavy/anime-tts",
  "keywords": ["anime", "tts", "elevenlabs", "sound-effects", "rei-ayanami", "kaomoji"],
  "author": {
    "name": "leancoderkavy",
    "url": "https://github.com/leancoderkavy"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/session-start.js",
            "timeout": 5,
            "statusMessage": "Powering up..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/prompt-submit.js",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/stop.js",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool.js",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/post-tool.js",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/session-end.js",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      }
    ]
  }
}
